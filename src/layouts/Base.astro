---
interface Props { title: string; description?: string; }
const { title, description = "n0t.space blog — Flipper Diaries & Attack→Defense" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="/" class="logo">n0t.space</a>
      <nav>
        <a href="/blog/">blog</a>
        <a href="/blog/series/flipper-diaries/">Flipper Diaries</a>
        <a href="/blog/series/attack-defense/">Attack→Defense</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer><p>_AstroN0T · <a href="/">n0t.space</a></p></footer>
    <style is:global>
      :root { color-scheme: dark; --fg:#e6e6e6; --bg:#0a0a0a; --accent:#5eead4; }
      body { margin:0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; background:var(--bg); color:var(--fg); line-height:1.65; }
      header { display:flex; justify-content:space-between; padding:1.5rem 2rem; border-bottom:1px solid #222; flex-wrap:wrap; gap:1rem; }
      .logo { font-weight:700; color:var(--accent); text-decoration:none; }
      nav a { color:var(--fg); margin-left:1rem; text-decoration:none; }
      nav a:hover { color:var(--accent); }
      main { max-width:760px; margin: 2.5rem auto; padding: 0 1.5rem; }
      footer { padding:2rem; border-top:1px solid #222; text-align:center; color:#888; }
      a { color: var(--accent); }
      article + article { margin-top: 2.5rem; padding-top: 2.5rem; border-top: 1px solid #222; }
      .meta { color:#888; font-size:.9rem; }
    </style>
  </body>
</html>
